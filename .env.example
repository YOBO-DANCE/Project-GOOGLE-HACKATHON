# =============================================================================
# Sports Concierge Agent - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your keys.
#   cp .env.example .env
#
# The app works in 3 modes (auto-detected at runtime):
#   MODE 1 (Best)  - Gemini API (cloud)  -> Set GEMINI_API_KEY below
#   MODE 2 (Good)  - Ollama (local)      -> No env vars needed, just run ollama serve
#   MODE 3 (Basic) - Baseline fallback   -> Always works, no API keys required
# =============================================================================

# --- Gemini API (RECOMMENDED for best quality plans) ---
# Get your free API key: https://aistudio.google.com/apikey
# GEMINI_API_KEY=your-gemini-api-key-here

# --- Ollama (Fallback - local LLM) ---
# Only needed if you want to use a different model than the default
# OLLAMA_MODEL=llama3.2:3b

# --- Supabase (Optional - for Security Audit Trail persistence) ---
# Get these from your Supabase project dashboard:
#   Project Settings > API > Project URL
#   Project Settings > API > anon / service_role key
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-supabase-anon-or-service-role-key

# --- App Password (Optional - for dashboard access control) ---
# If set, the Streamlit dashboard will require this password to access
# APP_PASSWORD=my-secret-password
